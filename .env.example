# ─── Doubao (火山引擎 Ark) AI Configuration ────────────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local to version control.
#
# Get ARK API key from: https://console.volcengine.com/ark
# Docs: https://www.volcengine.com/docs/82379/1399008
#
# Model used: doubao-seed-2-0-lite-260428 (豆包 seed 2.0 lite)
# Free tier available, cheap pricing
#

# Primary: Vite prefix (recommended for Vite projects)
VITE_ARK_API_KEY="your_ark_api_key_here"

# Fallback: bare key (some deployments inject this way)
ARK_API_KEY="your_ark_api_key_here"